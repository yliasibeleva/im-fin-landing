# Токен бота (получить у @MasterBot в Max)
BOT_TOKEN=

# ID администраторов через запятую (узнать через /myid в боте)
ADMIN_IDS=123456789,987654321

# Путь к SQLite базе данных
DB_PATH=data_storage/buh_bot.db

# Час отправки ежедневных напоминаний (МСК, 0–23)
REMINDER_HOUR=9

# За сколько дней до дедлайна отправлять напоминания (через запятую)
REMINDER_DAYS=14,7,3,1

# ID общей группы бухгалтеров (для утренней сводки и просроченных)
# Узнать: написать /myid в нужной группе
ACCOUNTANTS_GROUP_ID=

# ID группы руководителей (можно оставить пустым — тогда сводка идёт только в ACCOUNTANTS_GROUP_ID)
MANAGERS_GROUP_ID=
